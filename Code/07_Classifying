# R code for classifying imges

library(terra)
library(imageRy)

im.list

sun <- im.import("Solar_Orbiter_s_first_views_of_the_Sun_pillars.jpg")

#classificazione
sunc <- im.classify(sun, num_clusters = 3)
sunc <- im.classify(sun, num_clusters = 3, seed = 19) #seed in r è una funzione che definisce un iterazione da adottare 

